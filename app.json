{
  "expo": {
    "name": "Anioł Stróż",
    "slug": "aniol-stroz",
    "icon": "./assets/images/aniol_stroz_app_icon-iOS-Default-1024x1024.png",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "aniol-stroz",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.robert.aniolstroz"
    },
    "android": {
      "package": "com.robert.aniolstroz",
      "blockedPermissions": ["android.permission.WRITE_CONTACTS"],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/aniol_stroz_app_icon-iOS-Default-1024x1024.png",
        "backgroundColor": "#071826"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#071826",
          "image": "./app/assets/images/icon-stroz.png",
          "imageWidth": 180
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "Aplikacja potrzebuje dostępu do kontaktów, aby dodać osoby do Siatki wsparcia."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0675cfe9-9986-4706-b4a2-64b75c2c9f8e"
      }
    },
    "owner": "banasiewicz.rob"
  }
}
